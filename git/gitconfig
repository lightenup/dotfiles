[includeIf "gitdir:~/Development/ey/gh-enterprise/"]
  path = ~/Development/ey/gh-enterprise/.gitconfig_ey

[includeIf "gitdir:~/Development/private/"]
  path = ~/Development/private/.gitconfig_private

[includeIf "gitdir:~/Development/wilhem/"]
  path = ~/Development/wilhem/.gitconfig_wilhem

[core]
  hooksPath = ~/.config/git/hooks
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
